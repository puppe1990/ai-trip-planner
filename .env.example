# AI provider: gemini | nvidia-nim
AI_PROVIDER=gemini
# Optional model override (provider-specific default if empty)
AI_MODEL=

GEMINI_API_KEY=
NVIDIA_API_KEY=
TURSO_DATABASE_URL=file:./data/trip-planner.sqlite
TURSO_AUTH_TOKEN=
# Em dev, qualquer porta localhost funciona (ex.: 3000, 3001). Só precisa bater em produção.
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=
# Trip generation: true = multi-step (avoids Netlify timeout), false = single prompt
TRIP_PLANNER_MULTI_STEP=true